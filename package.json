{
  "name": "@xenition/sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for Xenition — auth, data, storage, chatbot, payments, push, email, AI, and more. Works in Node 18+ and Cloudflare Workers (with nodejs_compat).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/browser/index.js",
      "require": "./dist/browser/browser/index.js",
      "types": "./dist/browser/browser/index.d.ts"
    },
    "./hono": {
      "import": "./dist/hono/index.js",
      "require": "./dist/hono/index.js",
      "types": "./dist/hono/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:node && npm run build:browser",
    "build:node": "tsc",
    "build:browser": "tsc --project tsconfig.browser.json",
    "dev": "tsc --watch",
    "test": "jest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "xenition",
    "baas",
    "auth",
    "database",
    "storage",
    "payments",
    "chatbot",
    "push-notifications",
    "multi-tenant",
    "api-sdk"
  ],
  "author": "Xenition",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xenition/node-sdk.git"
  },
  "homepage": "https://github.com/xenition/node-sdk",
  "bugs": {
    "url": "https://github.com/xenition/node-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "form-data": "^4.0.5",
    "socket.io-client": "^4.8.3"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "hono": "^4.12.28",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
